# Copy this file to backend/.env and fill secrets locally.

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=gold

# App
LOG_LEVEL=INFO

# LLM
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.1
OLLAMA_BASE_URL=http://localhost:11434
GOOGLE_API_KEY=

# RAG / Vector store
# Use chroma until Qdrant Cloud is configured and indexed.
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# Qdrant Cloud
# Example URL: https://xxxx-yyyy.region.aws.cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=gold_news_chunks
QDRANT_TIMEOUT_SECONDS=30
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_TRUST_ENV=false

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Retrieval
RAG_TOP_K=8
RAG_CANDIDATE_K=24
RAG_MIN_CONTENT_LEN=200

# Chunking
RAG_SHORT_ARTICLE_TOKENS=450
RAG_MAX_CHUNK_TOKENS=320
RAG_MIN_CHUNK_TOKENS=80
RAG_CHUNK_OVERLAP_PARAGRAPHS=1
